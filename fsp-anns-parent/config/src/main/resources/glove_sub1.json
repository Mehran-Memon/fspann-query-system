{
  "opsThreshold": 500000000,
  "ageThresholdMs": 86400000,
  "reencryptionEnabled": false,
  "forwardSecurityEnabled": true,
  "profilerEnabled": true,

  "paper": {
    "enabled": true,
    "m": 20,
    "lambda": 2,
    "divisions": 16,
    "tables": 4,
    "seed": 13
  },

  "stabilization": {
    "enabled": false
  },

  "runtime": {
    "precisionMode": false,
    "probeOverride": -1,
    "refinementLimit": 6000,
    "maxCandidateFactor": 3,
    "maxGlobalCandidates": 8000,
    "maxRelaxationDepth": 5,
    "hammingPrefilterThreshold": 5
  },

  "eval": {
    "computePrecision": true,
    "writeGlobalPrecisionCsv": true,
    "kVariants": [1, 10, 20, 40, 60, 80, 100]
  },

  "ratio": {
    "source": "gt",
    "gtSample": 60,
    "gtMismatchTolerance": 0.08
  },

  "profiles": [
    {
      "name": "GLOVE_SUB1_P3_ULTRA",
      "description": "ULTRA FAST: semantic manifold (ratio-first, minimal candidates)",
      "overrides": {
        "paper": { "m": 18, "lambda": 2, "divisions": 20, "tables": 3 },
        "runtime": {
          "probeOverride": 3,
          "refinementLimit": 2000,
          "maxGlobalCandidates": 2800,
          "maxCandidateFactor": 2,
          "maxRelaxationDepth": 3,
          "hammingPrefilterThreshold": 7
        }
      }
    },
    {
      "name": "GLOVE_SUB1_P4_FAST",
      "description": "FAST: slightly higher probes but still sub-second oriented",
      "overrides": {
        "paper": { "m": 20, "lambda": 2, "divisions": 20, "tables": 3 },
        "runtime": {
          "probeOverride": 4,
          "refinementLimit": 3200,
          "maxGlobalCandidates": 4500,
          "maxCandidateFactor": 2,
          "maxRelaxationDepth": 4,
          "hammingPrefilterThreshold": 6
        }
      }
    },
    {
      "name": "GLOVE_SUB1_P6_RATIO",
      "description": "RATIO-LEANING: best chance to keep ratio tight while aiming <1s",
      "overrides": {
        "paper": { "m": 22, "lambda": 2, "divisions": 16, "tables": 4 },
        "runtime": {
          "probeOverride": 6,
          "refinementLimit": 5200,
          "maxGlobalCandidates": 7000,
          "maxCandidateFactor": 3,
          "maxRelaxationDepth": 5,
          "hammingPrefilterThreshold": 5
        }
      }
    }
  ]
}
