{
  "opsThreshold": 500000000,
  "ageThresholdMs": 86400000,
  "reencryptionEnabled": false,
  "forwardSecurityEnabled": true,
  "profilerEnabled": true,

  "paper": {
    "enabled": true,
    "m": 24,
    "lambda": 2,
    "divisions": 12,
    "tables": 5,
    "seed": 13
  },

  "stabilization": {
    "enabled": false
  },

  "runtime": {
    "precisionMode": false,
    "probeOverride": -1,
    "refinementLimit": 8000,
    "maxCandidateFactor": 3,
    "maxGlobalCandidates": 10000,
    "maxRelaxationDepth": 5,
    "hammingPrefilterThreshold": 4
  },

  "eval": {
    "computePrecision": true,
    "writeGlobalPrecisionCsv": true,
    "kVariants": [1, 10, 20, 40, 60, 80, 100]
  },

  "ratio": {
    "source": "gt",
    "gtSample": 80,
    "gtMismatchTolerance": 0.05
  },

  "profiles": [
    {
      "name": "SIFT_SUB1_P2_ULTRA",
      "description": "ULTRA FAST: sub-second attempt (ratio-first, recall sacrificed)",
      "overrides": {
        "paper": { "m": 18, "lambda": 2, "divisions": 16, "tables": 4 },
        "runtime": {
          "probeOverride": 2,
          "refinementLimit": 2500,
          "maxGlobalCandidates": 3500,
          "maxCandidateFactor": 2,
          "maxRelaxationDepth": 3,
          "hammingPrefilterThreshold": 6
        }
      }
    },
    {
      "name": "SIFT_SUB1_P4_FAST",
      "description": "FAST: sub-second target with better stability than ULTRA",
      "overrides": {
        "paper": { "m": 20, "lambda": 2, "divisions": 16, "tables": 4 },
        "runtime": {
          "probeOverride": 4,
          "refinementLimit": 4000,
          "maxGlobalCandidates": 5500,
          "maxCandidateFactor": 2,
          "maxRelaxationDepth": 4,
          "hammingPrefilterThreshold": 5
        }
      }
    },
    {
      "name": "SIFT_SUB1_P6_BAL",
      "description": "BALANCED UNDER 1s: highest chance to keep ratio close while staying fast",
      "overrides": {
        "paper": { "m": 22, "lambda": 2, "divisions": 12, "tables": 5 },
        "runtime": {
          "probeOverride": 6,
          "refinementLimit": 6000,
          "maxGlobalCandidates": 8000,
          "maxCandidateFactor": 3,
          "maxRelaxationDepth": 5,
          "hammingPrefilterThreshold": 4
        }
      }
    },
    {
      "name": "SIFT_SUB1_P6_BAL_REENC",
      "description": "SAME AS BALANCED but reencryption ON (measures forward-sec migration tax)",
      "overrides": {
        "reencryptionEnabled": true,
        "paper": { "m": 22, "lambda": 2, "divisions": 12, "tables": 5 },
        "runtime": {
          "probeOverride": 6,
          "refinementLimit": 6000,
          "maxGlobalCandidates": 8000,
          "maxCandidateFactor": 3,
          "maxRelaxationDepth": 5,
          "hammingPrefilterThreshold": 4
        }
      }
    }
  ]
}
