{
  "opsThreshold": 500000000,
  "ageThresholdMs": 86400000,
  "reencryptionEnabled": false,
  "forwardSecurityEnabled": true,
  "profilerEnabled": true,

  "paper": {
    "enabled": true,
    "m": 80,
    "lambda": 2,
    "divisions": 4,
    "tables": 8,
    "seed": 13
  },

  "stabilization": {
    "enabled": false
  },

  "runtime": {
    "precisionMode": false,
    "probeOverride": -1,
    "refinementLimit": 20000,
    "maxCandidateFactor": 6,
    "maxGlobalCandidates": 30000,
    "maxRelaxationDepth": 8,
    "hammingPrefilterThreshold": 0
  },

  "eval": {
    "computePrecision": true,
    "writeGlobalPrecisionCsv": true,
    "kVariants": [1, 10, 20, 40, 60, 80, 100]
  },

  "ratio": {
    "source": "gt",
    "gtSample": 100,
    "gtMismatchTolerance": 0.08
  },
