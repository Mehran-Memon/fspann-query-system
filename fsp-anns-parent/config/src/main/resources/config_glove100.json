{
  "opsThreshold": 500000000,
  "ageThresholdMs": 86400000,
  "reencryptionEnabled": false,
  "forwardSecurityEnabled": true,
  "profilerEnabled": true,

  "paper": {
    "enabled": true,
    "m": 16,
    "lambda": 3,
    "divisions": 4,
    "tables": 10,
    "seed": 13
  },

  "stabilization": {
    "enabled": true,
    "alpha": 0.30,
    "minCandidatesRatio": 1.5
  },

  "runtime": {
    "precisionMode": false,
    "probeOverride": -1,
    "refinementLimit": 40000,
    "maxCandidateFactor": 10,
    "maxGlobalCandidates": 50000,
    "maxRelaxationDepth": 9,
    "hammingPrefilterThreshold": 0
  },

  "eval": {
    "computePrecision": true,
    "writeGlobalPrecisionCsv": true,
    "kVariants": [1, 10, 20, 40, 60, 80, 100]
  },

  "ratio": {
    "source": "gt",
    "gtSample": 150,
    "gtMismatchTolerance": 0.05
  },
  "profiles":
    [
      {
        "name": "GLOVE_P4_FAST",
        "description": "BASELINE: Fast semantic lookup",
        "overrides": {
          "paper": { "m": 18, "lambda": 2, "divisions": 8, "tables": 5 },
          "runtime": {
            "probeOverride": 4,
            "refinementLimit": 9000,
            "maxGlobalCandidates": 12000,
            "maxCandidateFactor": 3,
            "maxRelaxationDepth": 5,
            "hammingPrefilterThreshold": 0
          }
        }
      },
      {
        "name": "GLOVE_P6_BALANCED",
        "description": "BALANCED: Semantic recall vs ART",
        "overrides": {
          "paper": { "m": 22, "lambda": 2, "divisions": 8, "tables": 6 },
          "runtime": {
            "probeOverride": 6,
            "refinementLimit": 16000,
            "maxGlobalCandidates": 20000,
            "maxRelaxationDepth": 7,
            "hammingPrefilterThreshold": 0
          }
        }
      },
      {
        "name": "GLOVE_TABLES8",
        "description": "ABLATION: More tables for semantic diversity",
        "overrides": {
          "paper": { "m": 22, "lambda": 2, "divisions": 8, "tables": 8 },
          "runtime": {
            "probeOverride": 6,
            "refinementLimit": 20000,
            "maxGlobalCandidates": 24000,
            "maxRelaxationDepth": 7,
            "hammingPrefilterThreshold": 0
          }
        }
      },
      {
        "name": "GLOVE_LAMBDA3",
        "description": "ABLATION: λ=3 on embeddings",
        "overrides": {
          "paper": { "m": 22, "lambda": 3, "divisions": 8, "tables": 6 },
          "runtime": {
            "probeOverride": 8,
            "refinementLimit": 22000,
