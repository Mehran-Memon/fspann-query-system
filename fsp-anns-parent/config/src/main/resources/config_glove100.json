            "maxRelaxationDepth": 9,
            "hammingPrefilterThreshold": 0
          }
        }
      },
      {
        "name": "GLOVE_DIV10_FINE",
        "description": "ABLATION: Finer partitions (precision oriented)",
        "overrides": {
          "paper": { "m": 22, "lambda": 2, "divisions": 10, "tables": 6 },
          "runtime": {
            "probeOverride": 6,
