{
  "opsThreshold": 500000000,
  "ageThresholdMs": 86400000,
  "reencryptionEnabled": false,
  "forwardSecurityEnabled": true,
  "profilerEnabled": true,

  "paper": {
    "enabled": true,
    "m": 16,
    "lambda": 2.5,
    "divisions": 4,
    "tables": 10,
    "seed": 13
  },

  "stabilization": {
    "enabled": true,
    "alpha": 0.30,
    "minCandidatesRatio": 1.5
  },

  "runtime": {
    "precisionMode": false,
    "probeOverride": -1,
    "refinementLimit": 40000,
    "maxCandidateFactor": 10,
    "maxGlobalCandidates": 50000,
    "maxRelaxationDepth": 9,
    "hammingPrefilterThreshold": 0
  },

  "eval": {
    "computePrecision": true,
    "writeGlobalPrecisionCsv": true,
    "kVariants": [1, 10, 20, 40, 60, 80, 100]
  },

  "ratio": {
    "source": "gt",
    "gtSample": 150,
    "gtMismatchTolerance": 0.05
  },
  "profiles":
    [
      {
        "name": "GLOVE_NUCLEAR_10K",
        "description": "RATIO WAR: High diversity tables (50) for semantic fidelity",
        "overrides": {
          "paper": { "m": 12, "lambda": 2, "divisions": 4, "tables": 50 },
          "runtime": { "refinementLimit": 10000, "maxGlobalCandidates": 20000 }
        }
      },
      {
        "name": "GLOVE_NUCLEAR_20K",
        "description": "RATIO WAR: Deep semantic search @ 20k limit",
        "overrides": {
          "paper": { "m": 12, "lambda": 2, "divisions": 4, "tables": 50 },
          "runtime": { "refinementLimit": 20000, "maxGlobalCandidates": 30000 }
        }
      },
      {
        "name": "GLOVE_NUCLEAR_30K",
        "description": "RATIO WAR: Peak semantic recall anchor point",
        "overrides": {
          "paper": { "m": 12, "lambda": 2, "divisions": 4, "tables": 50 },
          "runtime": { "refinementLimit": 30000, "maxGlobalCandidates": 45000 }
        }
      },
      {
        "name": "ABL_DIV8_SEMANTIC",
        "description": "ARCHITECTURAL ABLATION: Impact of fine-grained partitions (div=8) on GloVe",
        "overrides": {
          "paper": { "m": 12, "lambda": 2, "divisions": 8, "tables": 50 },
          "runtime": { "refinementLimit": 20000 }
        }
      }
