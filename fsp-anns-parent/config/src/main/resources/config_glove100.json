{
  "opsThreshold": 500000000,
  "ageThresholdMs": 86400000,
  "reencryptionEnabled": false,
  "forwardSecurityEnabled": true,
  "profilerEnabled": true,

  "paper": {
    "enabled": true,
    "m": 16,
    "lambda": 2.5,
    "divisions": 4,
    "tables": 10,
    "seed": 13
  },

  "stabilization": {
    "enabled": true,
    "alpha": 0.30,
    "minCandidatesRatio": 1.5
  },

  "runtime": {
    "precisionMode": false,
    "probeOverride": -1,
    "refinementLimit": 40000,
    "maxCandidateFactor": 10,
    "maxGlobalCandidates": 50000,
    "maxRelaxationDepth": 9,
    "hammingPrefilterThreshold": 0
  },

  "eval": {
    "computePrecision": true,
    "writeGlobalPrecisionCsv": true,
    "kVariants": [1, 10, 20, 40, 60, 80, 100]
  },

  "ratio": {
    "source": "gt",
    "gtSample": 150,
    "gtMismatchTolerance": 0.05
  },

  "profiles": [
    {
      "name": "P8_RESCUE_ALPHA",
      "description": "TARGET: >70% Recall. Strategy: Wide buckets (m=16) + Deep Scan (Alpha=0.3)",
      "overrides": {
        "paper": {
          "m": 16,
          "lambda": 2.5,
          "divisions": 4,
          "tables": 10
        },
        "stabilization": {
          "enabled": true,
          "alpha": 0.30,
          "minCandidatesRatio": 1.5
        },
        "runtime": {
          "probeOverride": 24,
          "refinementLimit": 45000,
          "maxGlobalCandidates": 60000
        }
      }
    },
    {
      "name": "P12_RESCUE_DEEP",
      "description": "BACKUP: Even deeper probe if P8 fails",
      "overrides": {
        "paper": {
          "m": 16,
          "lambda": 2.5,
          "divisions": 4,
          "tables": 10
        },
        "stabilization": {
          "enabled": true,
          "alpha": 0.40,
          "minCandidatesRatio": 2.0
        },
        "runtime": {
          "probeOverride": 32,
          "refinementLimit": 60000,
          "maxGlobalCandidates": 80000
        }
      }
    }
  ]
}