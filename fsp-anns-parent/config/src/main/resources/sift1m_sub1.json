{
  "opsThreshold": 500000000,
  "ageThresholdMs": 86400000,
  "reencryptionEnabled": false,
  "forwardSecurityEnabled": true,
  "profilerEnabled": true,

  "paper": {
    "enabled": true,
    "m": 24,
    "lambda": 2,
    "divisions": 12,
    "tables": 5,
    "seed": 13
  },

  "stabilization": { "enabled": false },

  "runtime": {
    "precisionMode": false,
    "probeOverride": -1,
    "refinementLimit": 6000,
    "maxCandidateFactor": 3,
    "maxGlobalCandidates": 8000,
    "maxRelaxationDepth": 5,
    "hammingPrefilterThreshold": 4
  },

  "eval": {
    "computePrecision": true,
    "writeGlobalPrecisionCsv": true,
    "kVariants": [1,10,20,40,60,80,100]
  },

  "ratio": {
    "source": "gt",
    "gtSample": 100,
    "gtMismatchTolerance": 0.05
  },

  "profiles": [

    {
      "name": "SIFT_UltraFast",
      "description": "<500ms extreme speed",
      "overrides": {
        "paper": { "m": 18, "lambda": 2, "divisions": 16, "tables": 4 },
        "runtime": {
          "probeOverride": 2,
          "refinementLimit": 2000,
          "maxGlobalCandidates": 3000,
          "maxCandidateFactor": 2,
          "maxRelaxationDepth": 3,
          "hammingPrefilterThreshold": 6
        }
      }
    },

    {
      "name": "SIFT_Fast",
      "description": "~700–900ms stable fast",
      "overrides": {
        "paper": { "m": 20, "lambda": 2, "divisions": 14, "tables": 4 },
        "runtime": {
          "probeOverride": 4,
          "refinementLimit": 3500,
          "maxGlobalCandidates": 5000,
          "maxCandidateFactor": 2,
          "maxRelaxationDepth": 4,
          "hammingPrefilterThreshold": 5
        }
      }
    },

    {
      "name": "SIFT_Balanced",
      "description": "best ratio under 1.5s",
      "overrides": {
        "paper": { "m": 22, "lambda": 2, "divisions": 12, "tables": 5 },
        "runtime": {
          "probeOverride": 6,
          "refinementLimit": 6000,
          "maxGlobalCandidates": 8000,
          "maxCandidateFactor": 3,
          "maxRelaxationDepth": 5,
          "hammingPrefilterThreshold": 4
        }
      }
    },

    {
      "name": "SIFT_HighRecall",
      "description": "competitive recall profile",
      "overrides": {
        "paper": { "m": 26, "lambda": 2, "divisions": 10, "tables": 6 },
        "runtime": {
          "probeOverride": 8,
          "refinementLimit": 10000,
          "maxGlobalCandidates": 14000,
          "maxCandidateFactor": 4,
          "maxRelaxationDepth": 6,
          "hammingPrefilterThreshold": 3
        }
      }
    },

    {
      "name": "SIFT_HighRecall_Reenc",
      "description": "forward-sec tax measurement",
      "overrides": {
        "reencryptionEnabled": true,
        "paper": { "m": 26, "lambda": 2, "divisions": 10, "tables": 6 },
        "runtime": {
          "probeOverride": 8,
          "refinementLimit": 10000,
          "maxGlobalCandidates": 14000,
          "maxCandidateFactor": 4,
          "maxRelaxationDepth": 6,
          "hammingPrefilterThreshold": 3
        }
      }
    }

  ]
}
